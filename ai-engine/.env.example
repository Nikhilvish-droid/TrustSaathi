# === TrustSaathi AI Engine Environment Variables ===

# Your Google Gemini API Key (get one at https://aistudio.google.com/apikey)
GEMINI_API_KEY=GOOGLE_GEMINI_API_KEY

# Developer 2's backend endpoint where extracted data will be sent
# Leave empty or remove if you don't want to forward data automatically
BACKEND_API_URL=http://localhost:3000/api/ai/upload

# Shared API key that must match AI_SERVICE_API_KEY in the backend .env file
BACKEND_API_KEY=replace_with_the_same_shared_internal_api_key

# To Use this engine provide the details gemini api key and backend api url 
# Then download the import packages and follow the commands given below to run the engine \

# 1. Create a fresh virtual environment in the new folderr
#  python -m venv venv

# 2. Activate it
#  venv\Scripts\activate

# 3. Re-install your libraries
#  pip install -r requirements.txt

