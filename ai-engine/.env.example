# === TrustSaathi AI Engine Environment Variables ===

# Single Gemini key OR comma-separated keys for faster throughput / rate-limit rotation
GEMINI_API_KEY=GOOGLE_GEMINI_API_KEY
# GEMINI_API_KEYS=key_one,key_two,key_three

# Fastest default: flash-lite. Use gemini-2.5-flash for slightly better accuracy.
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-2.5-flash,gemini-3.5-flash

# Resize large uploads before Gemini (longest edge in pixels; lower = faster)
# GEMINI_MAX_IMAGE_EDGE=1600

# Leave empty to skip auto-forward (recommended — upload flow saves via frontend)
BACKEND_API_URL=

# Shared API key that must match AI_SERVICE_API_KEY in the backend .env file
BACKEND_API_KEY=replace_with_the_same_shared_internal_api_key

# To Use this engine provide the details gemini api key and backend api url 
# Then download the import packages and follow the commands given below to run the engine \

# 1. Create a fresh virtual environment in the new folderr
#  python -m venv venv

# 2. Activate it
#  venv\Scripts\activate

# 3. Re-install your libraries
#  pip install -r requirements.txt

